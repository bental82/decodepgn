# Anthropic API key used by the /api/analyze serverless function.
# Set this in Vercel (Project Settings -> Environment Variables) for production,
# or export it in your shell for local `npm run dev`.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the strong model (defaults to claude-opus-4-8). Used for
# key moments in per-move analysis, the game overview, the cross-game "Your
# play" report, quiz and ask.
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: override the fast model (defaults to claude-sonnet-5). Used for
# routine per-move analysis — moves the engine check vouches for.
# ANTHROPIC_MODEL_FAST=claude-sonnet-5
